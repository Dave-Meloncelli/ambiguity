{
  "$schema": "https://opencode.ai/config.json",
  "name": "ambiguity-analyzer",
  "description": "Deterministic prompt analysis — pre-flight linter for human-to-model translation",
  "version": "0.1.0",
  "instructions": ["AGENTS.md", "QUICKSTART.md"],
  "model": {
    "provider": "auto",
    "reasoning": true
  },
  "tags": ["prompt-engineering", "llm-linting", "deterministic-analysis", "pre-flight", "guardrails"],
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "bash": "allow",
    "task": "allow",
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow"
  }
}
